---
import '../styles/global.css';

interface Section {
  href: string;
  title: string;
}
interface SectionGroup {
  label: string;
  items: Section[];
}

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  lede?: string;
  meta?: { time?: string; updated?: string; difficulty?: string };
  groups?: SectionGroup[];
  active?: string;
  isPrivate?: boolean;
  githubSource?: string;  // relative path do source MD na GitHubie (e.g. "docs/TUTORIAL.md")
}

const {
  title,
  description = 'Drureview — local on-prem AI code review for Drupal 11.',
  eyebrow,
  lede,
  meta,
  groups,
  active = '',
  isPrivate = false,
  githubSource,
} = Astro.props;

const GITHUB_REPO = 'bartek-filipiuk/local-codereviewer';
const githubEditUrl = githubSource
  ? `https://github.com/${GITHUB_REPO}/edit/main/${githubSource}`
  : null;

// Default sidebar groups jeśli nie podane
const defaultGroups: SectionGroup[] = [
  {
    label: 'Get started',
    items: [
      { href: '/docs/', title: 'Overview' },
      { href: '/docs/tutorial', title: 'Tutorial' },
      { href: '/docs/install', title: 'Install' },
    ],
  },
  {
    label: 'Reference',
    items: [
      { href: '/docs/usage', title: 'Usage (CLI + UI)' },
      { href: '/docs/architecture', title: 'Architecture' },
      { href: '/docs/security', title: 'Security' },
      { href: '/docs/changelog', title: 'Changelog' },
    ],
  },
];
const sidebarGroups = groups ?? defaultGroups;
---

<!doctype html>
<html lang="en" data-theme="light" data-accent="indigo" data-density="spacious">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content={description}>
  {isPrivate && (
    <>
      <meta name="robots" content="noindex,nofollow,noarchive,nosnippet">
      <meta name="googlebot" content="noindex,nofollow">
    </>
  )}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <title>{title} · Drureview</title>
</head>
<body>

  <!-- ===== NAV (compact wersja landing) ===== -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="brand">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="13" x2="15" y2="13"></line><line x1="9" y1="17" x2="15" y2="17"></line></svg>
        </span>
        <span>Drureview</span>
      </a>
      <div class="nav-links" role="navigation">
        <a href="/docs/" class="active">Docs</a>
        <a href="/#benchmark">Benchmarks</a>
        <a href="/#pricing">Pricing</a>
      </div>
      <div class="nav-actions">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
          <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
          <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path></svg>
        </button>
        <button class="btn btn-ghost" id="searchBtn" aria-label="Search docs">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          <span style="font-size:12px;color:var(--text-3)">⌘K</span>
        </button>
      </div>
    </div>
  </nav>

  <!-- ===== SHELL ===== -->
  <div class="docs-shell">

    <!-- Left sidebar -->
    <aside class="docs-sidebar" aria-label="Documentation sections">
      {sidebarGroups.map(group => (
        <div>
          <h4>{group.label}</h4>
          {group.items.map(item => (
            <a href={item.href} class={item.href === active ? 'active' : ''}>{item.title}</a>
          ))}
        </div>
      ))}
    </aside>

    <!-- Main content -->
    <main class="docs-content" id="docs-content">
      {isPrivate && (
        <div class="private-banner">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          <span><strong>Internal · confidential.</strong> Nie linkowane z landing/footer/sitemap. Nie publikuj URLs publicznie.</span>
        </div>
      )}

      <header class="docs-pageh">
        {eyebrow && <div class="eyebrow">{eyebrow}</div>}
        <h1>{title}</h1>
        {lede && <p class="lede">{lede}</p>}
        {meta && (
          <div class="meta">
            {meta.time && (
              <span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                {meta.time}
              </span>
            )}
            {meta.difficulty && (
              <span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                {meta.difficulty}
              </span>
            )}
            {meta.updated && (
              <span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9c-2.5 0-4.8 1-6.5 2.5L3 8"></path><polyline points="3 3 3 8 8 8"></polyline></svg>
                {meta.updated}
              </span>
            )}
          </div>
        )}
      </header>

      <slot />

      <!-- Page actions footer -->
      <div class="docs-page-actions">
        <div class="docs-actions">
          <button type="button" class="btn btn-ghost sm" onclick="window.print()">
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"></polyline><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path><rect x="6" y="14" width="12" height="8"></rect></svg>
            Print / PDF
          </button>
          {githubEditUrl && (
            <a href={githubEditUrl} target="_blank" rel="noopener" class="btn btn-ghost sm">
              <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
              Edit on GitHub
            </a>
          )}
        </div>

        {!isPrivate && (
          <div class="newsletter-cta">
            <div>
              <h4>Get launch updates</h4>
              <p>Pre-launch beta access, new features, no spam. Drupal community only.</p>
            </div>
            <form id="newsletterForm" class="newsletter-form">
              <input type="email" placeholder="you@agency.com" required aria-label="Email">
              <button type="submit" class="btn btn-accent sm">Subscribe</button>
            </form>
          </div>
        )}
      </div>
    </main>

    <!-- Right TOC (auto-generated by JS from h2/h3 in slot) -->
    <aside class="docs-toc-right" aria-label="On this page">
      <p class="toc-title">On this page</p>
      <ul id="toc-list"></ul>
    </aside>

  </div>

  <!-- ===== Cmd+K Search overlay ===== -->
  <div class="search-overlay" id="searchOverlay" role="dialog" aria-label="Search documentation">
    <div class="search-box">
      <div class="search-input-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" class="search-input" id="searchInput" placeholder="Search docs (sections, headers, content)…" autocomplete="off" autofocus>
        <span class="search-kbd">ESC</span>
      </div>
      <div class="search-results" id="searchResults">
        <div class="empty">Type to search…</div>
      </div>
    </div>
  </div>

  <!-- ===== JS: dark mode toggle, TOC scroll-spy, copy buttons, Cmd+K search, print ===== -->
  <script is:inline>
    /* ===== Theme persisted ===== */
    const PREF_KEY = 'dcr-docs-prefs-v1';
    const state = Object.assign(
      { theme: 'light' },
      JSON.parse(localStorage.getItem(PREF_KEY) || '{}')
    );
    function applyTheme() {
      document.documentElement.setAttribute('data-theme', state.theme);
    }
    function persist(patch) {
      Object.assign(state, patch);
      localStorage.setItem(PREF_KEY, JSON.stringify(state));
      applyTheme();
    }
    document.getElementById('themeToggle').addEventListener('click', () => {
      persist({ theme: state.theme === 'light' ? 'dark' : 'light' });
    });
    applyTheme();

    /* ===== Nav scroll shadow ===== */
    const nav = document.querySelector('.nav');
    const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 8);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* ===== Auto TOC z h2/h3 w content ===== */
    function slugify(text) {
      return String(text).toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-').replace(/-+/g, '-').slice(0, 60);
    }
    const content = document.getElementById('docs-content');
    const tocList = document.getElementById('toc-list');
    if (content && tocList) {
      const headers = content.querySelectorAll('h2, h3');
      headers.forEach(h => {
        if (!h.id) h.id = slugify(h.textContent || '');
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent || '';
        a.classList.add('lvl-' + h.tagName.slice(1));
        li.appendChild(a);
        tocList.appendChild(li);
      });

      /* Scroll spy */
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const link = tocList.querySelector(`a[href="#${id}"]`);
          if (!link) return;
          if (entry.isIntersecting) {
            tocList.querySelectorAll('a').forEach(a => a.classList.remove('active'));
            link.classList.add('active');
          }
        });
      }, { rootMargin: '-80px 0px -65% 0px' });
      headers.forEach(h => observer.observe(h));
    }

    /* ===== Copy buttons dla code blocks ===== */
    document.querySelectorAll('.code-block').forEach(block => {
      const btn = block.querySelector('.copy-btn');
      const pre = block.querySelector('pre');
      if (!btn || !pre) return;
      btn.addEventListener('click', async () => {
        const text = pre.textContent || '';
        try {
          await navigator.clipboard.writeText(text);
          const original = btn.innerHTML;
          btn.classList.add('copied');
          btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Copied';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML = original;
          }, 1600);
        } catch (e) {
          console.warn('Copy failed:', e);
        }
      });
    });

    /* ===== Cmd+K search ===== */
    const searchOverlay = document.getElementById('searchOverlay');
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    const searchBtn = document.getElementById('searchBtn');

    function buildSearchIndex() {
      // Index all h1/h2/h3 + paragraph snippets
      const idx = [];
      content.querySelectorAll('h1, h2, h3').forEach(h => {
        if (!h.id) h.id = slugify(h.textContent || '');
        // Find next paragraph or content snippet
        let snippet = '';
        let next = h.nextElementSibling;
        while (next && !['H1','H2','H3'].includes(next.tagName)) {
          if (next.textContent) snippet = (snippet + ' ' + next.textContent).trim().slice(0, 180);
          if (snippet.length > 100) break;
          next = next.nextElementSibling;
        }
        idx.push({ title: h.textContent || '', id: h.id, snippet, level: parseInt(h.tagName.slice(1)) });
      });
      return idx;
    }
    let searchIndex = [];
    let focusedIdx = -1;

    function openSearch() {
      if (!searchIndex.length) searchIndex = buildSearchIndex();
      searchOverlay.classList.add('is-open');
      searchInput.value = '';
      focusedIdx = -1;
      renderResults('');
      setTimeout(() => searchInput.focus(), 30);
    }
    function closeSearch() {
      searchOverlay.classList.remove('is-open');
    }
    function highlight(text, q) {
      if (!q) return text;
      const re = new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'ig');
      return text.replace(re, '<mark>$1</mark>');
    }
    function renderResults(query) {
      const q = query.trim().toLowerCase();
      let matches = searchIndex;
      if (q) {
        matches = searchIndex.filter(it =>
          it.title.toLowerCase().includes(q) ||
          it.snippet.toLowerCase().includes(q)
        );
      }
      if (!matches.length) {
        searchResults.innerHTML = '<div class="empty">No matches for "' + q + '"</div>';
        return;
      }
      searchResults.innerHTML = matches.slice(0, 12).map((it, i) =>
        `<a class="search-result ${i === focusedIdx ? 'focused' : ''}" href="#${it.id}" data-idx="${i}">
          <div class="title">${highlight(it.title, q)}</div>
          ${it.snippet ? `<div class="snippet">${highlight(it.snippet, q)}</div>` : ''}
        </a>`
      ).join('');
      searchResults.querySelectorAll('.search-result').forEach(el => {
        el.addEventListener('click', () => { closeSearch(); });
      });
    }
    searchInput && searchInput.addEventListener('input', e => {
      focusedIdx = -1;
      renderResults(e.target.value);
    });
    searchBtn && searchBtn.addEventListener('click', openSearch);

    document.addEventListener('keydown', e => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      } else if (e.key === 'Escape' && searchOverlay.classList.contains('is-open')) {
        closeSearch();
      } else if (searchOverlay.classList.contains('is-open')) {
        const results = searchResults.querySelectorAll('.search-result');
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          focusedIdx = Math.min(results.length - 1, focusedIdx + 1);
          results.forEach((r, i) => r.classList.toggle('focused', i === focusedIdx));
          results[focusedIdx]?.scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          focusedIdx = Math.max(0, focusedIdx - 1);
          results.forEach((r, i) => r.classList.toggle('focused', i === focusedIdx));
          results[focusedIdx]?.scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter' && focusedIdx >= 0) {
          e.preventDefault();
          results[focusedIdx]?.click();
          window.location.hash = results[focusedIdx].getAttribute('href');
          closeSearch();
        }
      }
    });
    searchOverlay && searchOverlay.addEventListener('click', e => {
      if (e.target === searchOverlay) closeSearch();
    });
  </script>

  <!-- Newsletter form stub (placeholder do real backend) -->
  <script is:inline>
    (function() {
      const form = document.getElementById('newsletterForm');
      if (!form) return;
      form.addEventListener('submit', e => {
        e.preventDefault();
        const input = form.querySelector('input');
        const btn = form.querySelector('button');
        input.value = '';
        btn.textContent = '✓ On the list';
        btn.disabled = true;
      });
    })();
  </script>

  <slot name="extra-scripts" />
</body>
</html>
