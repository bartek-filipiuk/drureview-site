---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Drureview — AI code review for Drupal that never leaves your network',
  description = 'On-prem, Drupal-aware AI code review. Runs on your hardware, 0% data egress, one-time license. Free local core; paid auto-fix, MCP, and CI.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light" data-accent="indigo" data-density="spacious" data-hero-style="gitlab">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content={description}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>
