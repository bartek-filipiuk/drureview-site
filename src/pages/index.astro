  <script is:inline>
    /* ===== Theme state (persisted to localStorage) ===== */
    const STORAGE_KEY = 'dcr-prefs-v1';
    const state = Object.assign(
      { theme: 'light' },
      JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}')
    );

    function apply() {
      document.documentElement.setAttribute('data-theme', state.theme);
    }

    function persist(patch) {
      Object.assign(state, patch);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      apply();
    }

    document.getElementById('themeToggle').addEventListener('click', () => {
      persist({ theme: state.theme === 'light' ? 'dark' : 'light' });
    });

    /* ===== Nav scroll shadow ===== */
    const nav = document.querySelector('.nav');
    const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 8);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* ===== Reveal-on-scroll ===== */
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: '0px 0px -40px 0px', threshold: 0.05 });
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));

    /* ===== CTA form (placeholder until backend wired) ===== */
    document.getElementById('ctaForm').addEventListener('submit', e => {
      e.preventDefault();
      const input = e.currentTarget.querySelector('input');
      const btn = e.currentTarget.querySelector('.btn');
      input.value = '';
      btn.textContent = '✓ On the list';
    });

    /* ===== Scanner waitlist (placeholder until backend wired) ===== */
    const sw = document.getElementById('scanWaitlist');
    if (sw) sw.addEventListener('submit', e => {
      e.preventDefault();
      sw.querySelector('input').value = '';
      sw.querySelector('.btn').textContent = '✓ On the list';
    });

    /* ===== Founding seats counter (static until backend wired) ===== */
    const fl = document.getElementById('foundingLeft');
    if (fl) fl.textContent = fl.dataset.cap; // swap to a live Stripe count at deploy

    /* ===== Stripe Payment Links ====================================
       >>> PASTE PAYMENT LINKS HERE before launch <<<  (Bartek)
       Replace each '#' with the Stripe Payment Link URL
       (https://buy.stripe.com/...). Until filled, a button falls back
       to the #pricing section instead of a broken '#'. ============= */
    const STRIPE = {
      'solo': '#',             // Solo $39 one-time
      'agency-founding': '#',  // Agency FOUNDING $190 one-time, qty-capped at 50
      'agency': '#',           // Agency $290 one-time (after founding sells out)
      'site': '#',             // Site $1,250 one-time
      'svc-quickstart': '#',   // Quickstart $390 service
    };
    document.querySelectorAll('[data-stripe]').forEach(a => {
      const url = STRIPE[a.dataset.stripe];
      if (url && url !== '#') {
        a.setAttribute('href', url);
      } else {
        a.setAttribute('href', '#pricing');
        a.setAttribute('title', 'Checkout link coming at launch');
      }
    });

    apply();
  </script>
</Layout>
