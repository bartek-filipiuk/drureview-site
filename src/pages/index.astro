      <div class="nav-actions">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode">
          <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
          <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path></svg>
        </button>
        <a href="mailto:filipiuk.bartek@gmail.com?subject=Drureview%20demo" class="btn btn-ghost">Book demo</a>
        <a href="#pricing" class="btn btn-primary">
          Get Drureview
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
    </div>
  </nav>

  <main>

    <!-- ===================== HERO ===================== -->
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <span class="status-badge">
            <span class="pulse" aria-hidden="true"></span>
            <strong>Launching &lt;date&gt;</strong> · One-time license · Drupal community
          </span>

          <h1>
            AI code review for Drupal<br />
            <span class="muted">on your hardware. Buy it once.</span>
          </h1>

          <p class="hero-sub">
            A Drupal-aware reviewer that runs inside your network — CLI, your IDE (MCP), or as a PR bot. It knows <code class="mono">#[Hook]</code>, cache contexts, DI, and render-array XSS, and it can hand you the fix as a one-click suggestion. No subscription, no data leaving the building.
          </p>

          <div class="hero-ctas">
            <a href="#pricing" class="btn btn-accent btn-lg">
              Get Drureview
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
            <a href="#benchmark" class="btn btn-outline btn-lg">Read the benchmark</a>
          </div>

          <div class="hero-meta">
            <span><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Free local core</span>
            <span><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Buy once</span>
            <span><svg class="check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg> Self-hosted</span>
          </div>
        </div>

        <div class="hero-mockup-slot">

          <!-- variant: GitLab MR mockup -->
          <div class="mr-mockup" role="img" aria-label="GitLab MR comment example">
            <div class="mr-tab">
              <span class="dots" aria-hidden="true"><span></span><span></span><span></span></span>
              <span>gitlab · acme/drupal-site</span>
              <span class="branch mono">!247 feature/user-search</span>
              <span class="right">
                <span class="pill-open">Open</span>
              </span>
            </div>

            <article class="mr-comment">
              <div class="mr-avatar" aria-hidden="true">DC</div>
              <div class="mr-body">
                <header class="mr-meta">
                  <span class="name">drupal-codereviewer</span>
                  <span class="bot">BOT</span>
                  <span class="sep">·</span>
                  <span>commented on <code class="mono">src/Form/UserSearchForm.php</code></span>
                  <span class="sep">·</span>
                  <span>2 minutes ago</span>
                </header>
                <p class="mr-text">
                  <span class="sev-badge sev-critical">CRITICAL · SQL injection</span>
                  Raw <code>$keyword</code> concatenated into <code>db_query()</code>. Bypasses Drupal's prepared-statement layer. Use a placeholder.
                </p>
                <div class="diff">
                  <div class="diff-file mono">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:11px;height:11px"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                    src/Form/UserSearchForm.php · line 47
                  </div>
                  <div class="diff-row del"><span class="ln">47</span><span class="marker">-</span><span class="code">{`$result = db_query("SELECT * FROM {users} WHERE name LIKE '%" . $keyword . "%'");`}</span></div>
                  <div class="diff-row add"><span class="ln">47</span><span class="marker">+</span><span class="code">$result = $this-&gt;database-&gt;select('users', 'u')</span></div>
                  <div class="diff-row add"><span class="ln">48</span><span class="marker">+</span><span class="code">  -&gt;condition('name', '%' . $this-&gt;database-&gt;escapeLike($keyword) . '%', 'LIKE')</span></div>
                  <div class="diff-row add"><span class="ln">49</span><span class="marker">+</span><span class="code">  -&gt;execute();</span></div>
                </div>
                <div class="mr-actions">
                  <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px"><polyline points="9 17 4 12 9 7"></polyline><path d="M20 18v-2a4 4 0 0 0-4-4H4"></path></svg> Reply</a>
                  <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px"><polyline points="20 6 9 17 4 12"></polyline></svg> Resolve thread</a>
                </div>
              </div>
            </article>

            <article class="mr-comment">
              <div class="mr-avatar" aria-hidden="true">DC</div>
              <div class="mr-body">
                <header class="mr-meta">
                  <span class="name">drupal-codereviewer</span>
                  <span class="bot">BOT</span>
                  <span class="sep">·</span>
                  <span>commented on <code class="mono">src/Controller/UserController.php</code></span>
                  <span class="sep">·</span>
                  <span>2 minutes ago</span>
                </header>
                <p class="mr-text">
                  <span class="sev-badge sev-medium">MEDIUM · DI antipattern</span>
                  Static <code>\Drupal::service('entity_type.manager')</code> inside controller. Inject via <code>create()</code> instead — keeps the controller testable.
                </p>
                <div class="mr-actions">
                  <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px"><polyline points="9 17 4 12 9 7"></polyline><path d="M20 18v-2a4 4 0 0 0-4-4H4"></path></svg> Reply</a>
                  <a href="#"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:13px;height:13px"><polyline points="20 6 9 17 4 12"></polyline></svg> Resolve thread</a>
                </div>
              </div>
            </article>
          </div>

          <!-- variant: terminal mockup -->
          <div class="terminal-mockup">
            <div class="terminal-bar">
              <span class="tdot"></span><span class="tdot"></span><span class="tdot"></span>
              <span class="ttitle">~/drupal-site $ drupal-cr review !247</span>
            </div>
            <div class="terminal-body mono">
              <div><span class="prompt">→</span> <span class="dim">Connecting to local Ollama (gemma4-12b-dcr) ……… </span><span class="ok">ok</span></div>
              <div><span class="prompt">→</span> <span class="dim">Indexing Drupal RAG (core + 84 contrib) ……… </span><span class="ok">1,968 vectors</span></div>
              <div><span class="prompt">→</span> <span class="dim">Reviewing 3 changed files (412 LOC) ……… </span><span class="ok">28.4s</span></div>
              <div style="height:10px"></div>
              <div><span class="err">●</span> <span class="err">CRITICAL</span> <span class="dim">src/Form/UserSearchForm.php:47</span></div>
              <div>&nbsp;&nbsp;<span class="dim">SQL injection — raw concat into db_query()</span></div>
              <div>&nbsp;&nbsp;<span class="arrow">└</span> <span class="dim">use $this-&gt;database-&gt;select() with placeholder</span></div>
              <div style="height:8px"></div>
              <div><span class="warn">●</span> <span class="warn">MEDIUM</span> <span class="dim">src/Controller/UserController.php:22</span></div>
              <div>&nbsp;&nbsp;<span class="dim">DI antipattern — \Drupal::service() in controller</span></div>
              <div><span class="warn">●</span> <span class="warn">MEDIUM</span> <span class="dim">src/Plugin/Block/StatsBlock.php:61</span></div>
              <div>&nbsp;&nbsp;<span class="dim">missing #cache.contexts on user-specific render</span></div>
              <div style="height:10px"></div>
              <div><span class="dim">Findings posted to GitLab MR !247 (2 critical, 4 medium, 1 low)</span></div>
            </div>
          </div>

          <!-- variant: diff-only mockup -->
          <div class="diff-only-mockup">
            <div class="diff" style="margin:0;border-radius:0">
              <div class="diff-file mono">src/Form/UserSearchForm.php · line 47</div>
              <div class="diff-row del"><span class="ln">47</span><span class="marker">-</span><span class="code">{`$result = db_query("SELECT * FROM {users} WHERE name LIKE '%" . $keyword . "%'");`}</span></div>
              <div class="diff-row add"><span class="ln">47</span><span class="marker">+</span><span class="code">$result = $this-&gt;database-&gt;select('users', 'u')</span></div>
              <div class="diff-row add"><span class="ln">48</span><span class="marker">+</span><span class="code">  -&gt;condition('name', '%' . $this-&gt;database-&gt;escapeLike($keyword) . '%', 'LIKE')</span></div>
              <div class="diff-row add"><span class="ln">49</span><span class="marker">+</span><span class="code">  -&gt;execute();</span></div>
            </div>
            <div class="annotation">
              <span class="sev-badge sev-critical">CRITICAL</span>
              <div>
                <strong>SQL injection</strong> — raw <code class="mono">$keyword</code> concatenated into <code class="mono">db_query()</code>.
                Use the database service with a placeholder so Drupal's prepared statements escape it for you.
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- ===== Trust strip (right under hero) ===== -->
      <div class="container">
        <div class="trust">
          <p class="trust-label">In production with beta partners across these sectors — logos coming after public launch</p>
          <div class="trust-row">
            <div class="trust-slot">Drupal agency</div>
            <div class="trust-slot">University</div>
            <div class="trust-slot">Government</div>
            <div class="trust-slot">Healthcare</div>
            <div class="trust-slot">Finance</div>
          </div>
        </div>
      </div>
    </section>


    <!-- ===================== PROBLEMS ===================== -->
    <section id="problems">
      <div class="container">
        <span class="section-label">Why teams ship this</span>
        <h2 class="section-title">Three problems generic AI reviewers miss on Drupal.</h2>
        <p class="section-lede">CodeRabbit / Greptile / Copilot are trained on a generic corpus. They don't know <code class="mono">#[Hook]</code>, cache contexts, or Drupal's service container — so they either silently pass or hallucinate.</p>

        <div class="problem-grid">
          <article class="card reveal">
            <div class="card-icon rose" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <h3>Review queue bottleneck</h3>
            <p>Senior devs spend 6–9 hrs/week reviewing routine MRs. By the time they get to yours, the context is gone and the comment is "LGTM, ship it."</p>
            <div class="micro">
              <div class="micro-row"><span class="m">›</span><span class="c">42 open MRs · waiting for tech lead</span></div>
              <div class="micro-row"><span class="m">›</span><span class="c">avg time to first review: 2.3 days</span></div>
              <div class="micro-row add"><span class="m">+</span><span class="c">first AI review: &lt;30s, full diff</span></div>
            </div>
          </article>

          <article class="card reveal">
            <div class="card-icon amber" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
            </div>
            <h3>D11.1+ migration burden</h3>
            <p>Hook attributes, OOP plugins, deprecated <code class="mono">drupal_get_path()</code>. The lint rules catch some — but missing them in review costs a sprint of refactor later.</p>
            <div class="micro">
              <div class="micro-row del"><span class="m">−</span><span class="c">function my_module_node_view(...) {`{`}</span></div>
              <div class="micro-row add"><span class="m">+</span><span class="c">#[Hook('node_view')]</span></div>
              <div class="micro-row add"><span class="m">+</span><span class="c">public function nodeView(...) {`{`}</span></div>
            </div>
          </article>

          <article class="card reveal">
            <div class="card-icon sky" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
            </div>
            <h3>Subtle Drupal idioms</h3>
            <p>Missing <code class="mono">#cache.contexts</code>, raw entity loads in loops, render arrays that won't BigPipe. Generic tools don't flag any of these — your prod alerts do.</p>
            <div class="micro">
              <div class="micro-row"><span class="m">›</span><span class="c">{`$build['#markup'] = $node->getTitle();`}</span></div>
              <div class="micro-row del"><span class="m">−</span><span class="c">// no #cache.contexts → leaks</span></div>
              <div class="micro-row add"><span class="m">+</span><span class="c">{`'#cache' => ['contexts' => ['user']]`}</span></div>
            </div>
          </article>
        </div>
      </div>
    </section>


    <!-- ===================== HOW IT WORKS ===================== -->
    <section id="how">
      <div class="container">
        <span class="section-label">How it works</span>
        <h2 class="section-title">Five hops, all of them inside your network.</h2>
        <p class="section-lede">The MR webhook fires, the model reviews, GitLab gets a comment back. The whole pipeline runs on infrastructure you already own — no API calls leave your VPC.</p>

        <div class="pipeline">
          <article class="pipeline-step reveal">
            <span class="num mono">01</span>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="6" r="3"></circle><circle cx="6" cy="18" r="3"></circle><path d="M18 9v3a3 3 0 0 1-3 3H9"></path><path d="M9 12v6"></path></svg></span>
            <h4>GitLab MR</h4>
            <p>Webhook on push or comment trigger.</p>
            <span class="stack">GitLab CE 16+</span>
            <span class="pipeline-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></span>
          </article>

          <article class="pipeline-step reveal">
            <span class="num mono">02</span>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h7"></path><path d="M16 17l5 5"></path><circle cx="17" cy="17" r="4"></circle></svg></span>
            <h4>Diff parse</h4>
            <p>FastAPI extracts changed hunks + file context.</p>
            <span class="stack">FastAPI · Python 3.12</span>
            <span class="pipeline-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></span>
          </article>

          <article class="pipeline-step reveal">
            <span class="num mono">03</span>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"></ellipse><path d="M3 5v14a9 3 0 0 0 18 0V5"></path><path d="M3 12a9 3 0 0 0 18 0"></path></svg></span>
            <h4>Drupal-RAG lookup</h4>
            <p>Pulls relevant core docs, contrib patterns, prior fixes.</p>
            <span class="stack">Qdrant</span>
            <span class="pipeline-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></span>
          </article>

          <article class="pipeline-step reveal">
            <span class="num mono">04</span>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="2" x2="9" y2="4"></line><line x1="15" y1="2" x2="15" y2="4"></line><line x1="9" y1="20" x2="9" y2="22"></line><line x1="15" y1="20" x2="15" y2="22"></line><line x1="20" y1="9" x2="22" y2="9"></line><line x1="20" y1="14" x2="22" y2="14"></line><line x1="2" y1="9" x2="4" y2="9"></line><line x1="2" y1="14" x2="4" y2="14"></line></svg></span>
            <h4>Local LLM review</h4>
            <p>Ollama runs gemma4-12b-dcr on your hardware.</p>
            <span class="stack">Ollama · gemma4-12b-dcr</span>
            <span class="pipeline-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg></span>
          </article>

          <article class="pipeline-step reveal">
            <span class="num mono">05</span>
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg></span>
            <h4>MR comment</h4>
            <p>Findings posted inline. Severity, file, line.</p>
            <span class="stack">GitLab API v4</span>
          </article>
        </div>

        <div class="differentiators reveal">
          <div class="diff-item">
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg></span>
            <div>
              <p class="t">0% data egress</p>
              <p class="d">Code never crosses your VPC boundary. No vendor API. Auditable.</p>
            </div>
          </div>
          <div class="diff-item">
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg></span>
            <div>
              <p class="t">&lt;30s review</p>
              <p class="d">Average pipeline run from webhook to inline MR comment. Posts before the senior dev opens GitLab.</p>
            </div>
          </div>
          <div class="diff-item">
            <span class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><polyline points="2 17 12 22 22 17"></polyline></svg></span>
            <div>
              <p class="t">Drupal-RAG</p>
              <p class="d">14k vectors over core, top-200 contrib, and your own custom modules — so the model knows your hooks too.</p>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ===================== SURFACES + FIX ===================== -->
<section id="surfaces">
  <div class="container">
    <span class="section-label">One engine, three doors</span>
    <h2 class="section-title">Run it where you already work.</h2>
    <p class="section-lede">Same review pipeline, same local model, reached three ways. The CLI is the free core; the IDE (MCP) and PR-bot doors are Pro.</p>

    <div class="problem-grid">
      <article class="card reveal">
        <div class="card-icon sky" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
        </div>
        <h3>CLI &amp; git hook <span style="font-size:10px;font-weight:700;letter-spacing:.06em;padding:2px 7px;border-radius:999px;border:1px solid currentColor;vertical-align:middle;margin-left:6px;opacity:.6">FREE</span></h3>
        <p>Pipe a diff in, get JSON or markdown back. Wire it into a pre-push hook so nothing merges unreviewed.</p>
        <div class="micro">
          <div class="micro-row"><span class="m">$</span><span class="c">git diff main | drureview review --diff-stdin</span></div>
        </div>
      </article>

      <article class="card reveal">
        <div class="card-icon amber" aria-hidden="true">
