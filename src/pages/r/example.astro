---
import Layout from '../../layouts/Layout.astro';

// EXAMPLE / scaffold result page. The live public scanner (drureview.com/r/<id>)
// will render one of these per public MR with REAL findings. Until then this is a
// representative placeholder so the teaser cards link somewhere real-looking.
const findings = [
  { sev: 'high',   cat: 'security',     loc: 'src/Controller/TokenController.php:88', cwe: 'CWE-285', msg: 'entityQuery() without an explicit ->accessCheck() — may return tokens the current user cannot access.' },
  { sev: 'medium', cat: 'architecture', loc: 'src/Controller/TokenController.php:42', msg: 'Static \\Drupal::service() in a controller — inject the service via create()/__construct() instead (testability + Drupal DI idiom).' },
  { sev: 'medium', cat: 'drupal_api',   loc: 'src/Plugin/Block/StatsBlock.php:30',  msg: 'Render array returns user-specific markup without #cache.contexts (\'user\') — risks cross-user cache bleed.' },
];
const sevColor = { critical: '#e5484d', high: '#e5484d', medium: '#f5a623', low: '#3b82f6' };
---
<Layout
  title="Drureview review · example Drupal MR (sample)"
  description="A sample Drupal-aware Drureview review of a public merge request — access checks, DI, cache metadata. The live public scanner launches soon."
>
  <main style="max-width:760px;margin:0 auto;padding:48px 20px;font-family:Inter,system-ui,sans-serif">

    <div style="font-size:12px;font-weight:600;letter-spacing:.04em;text-transform:uppercase;opacity:.6;border:1px dashed currentColor;border-radius:8px;padding:8px 12px;margin-bottom:24px">
      Example result — the live public scanner launches soon. Numbers below are a sample.
    </div>

    <h1 style="font-size:28px;margin:0 0 6px">Drureview review · <span style="font-family:'JetBrains Mono',monospace">example Drupal MR</span></h1>
    <p style="opacity:.7;margin:0 0 20px">
      Reviewed by <strong>Drureview</strong> · model <code style="font-family:'JetBrains Mono',monospace">gemma4-12b-dcr-v7</code> · on your own hardware, 0% data egress.
    </p>

    <div style="display:flex;gap:10px;align-items:center;margin-bottom:28px">
      <span style="background:#f5a623;color:#1a1a1a;font-weight:700;font-size:13px;padding:4px 12px;border-radius:999px">Risk: medium</span>
      <span style="opacity:.6;font-size:14px">3 findings · 1 high · 2 medium · high specificity (low false alarms)</span>
    </div>

    {findings.map((f) => (
      <div style="border:1px solid rgba(128,128,128,.25);border-radius:12px;padding:16px 18px;margin-bottom:12px">
        <div style="display:flex;gap:10px;align-items:center;margin-bottom:6px">
          <span style={`background:${sevColor[f.sev]};color:#fff;font-weight:700;font-size:11px;letter-spacing:.04em;text-transform:uppercase;padding:2px 9px;border-radius:999px`}>{f.sev}</span>
          <span style="font-size:12px;font-weight:600;opacity:.6;text-transform:uppercase;letter-spacing:.04em">{f.cat}</span>
          {f.cwe && <span style="font-size:12px;font-family:'JetBrains Mono',monospace;opacity:.6">{f.cwe}</span>}
        </div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:13px;opacity:.75;margin-bottom:6px">{f.loc}</div>
        <div style="font-size:15px;line-height:1.5">{f.msg}</div>
      </div>
    ))}

    <div style="margin-top:32px;border-top:1px solid rgba(128,128,128,.2);padding-top:24px">
      <p style="font-size:15px;line-height:1.6;margin:0 0 16px">
        This ran on a <strong>public</strong> merge request. For your <strong>private</strong> code,
        run Drureview locally — nothing leaves your network. That's the whole point.
      </p>
      <a href="/#pricing" style="display:inline-block;background:#4f46e5;color:#fff;font-weight:600;padding:11px 20px;border-radius:10px;text-decoration:none">Get Drureview →</a>
      <a href="/" style="display:inline-block;margin-left:10px;padding:11px 16px;text-decoration:none;opacity:.75">Back to drureview.com</a>
    </div>

  </main>
</Layout>
